{
  "meta": {
    "name": "01-button: Basic Input Units",
    "version": "1.0",
    "author": "Omnipad",
    "description": "This example demonstrates the core building blocks of virtual interaction. It features a standard keyboard-mapped button on the left and a fixed-point mouse button on the right, highlighting the library's ability to simulate both key presses and precision clicks."
  },
  "items": [
    {
      "id": "$left-pad",
      "type": "root-layer",
      "config": {
        "layout": {
          "left": 0,
          "top": 0,
          "width": "100%",
          "height": "100%"
        },
        "baseType": "root-layer"
      }
    },
    {
      "id": "$right-pad",
      "type": "root-layer",
      "config": {
        "layout": {
          "left": 0,
          "top": 0,
          "width": "100%",
          "height": "100%"
        },
        "baseType": "root-layer"
      }
    },
    {
      "id": "node_1",
      "type": "button",
      "parentId": "$left-pad",
      "config": {
        "label": "SPACE",
        "targetStageId": "$ruffle-player",
        "mapping": {
          "key": " "
        },
        "layout": {
          "left": "50%",
          "top": "70%",
          "height": 80,
          "width": "80px",
          "anchor": "center"
        },
        "baseType": "button"
      }
    },
    {
      "id": "node_2",
      "type": "button",
      "parentId": "$right-pad",
      "config": {
        "label": "POINT",
        "targetStageId": "$ruffle-player",
        "mapping": {
          "type": "mouse",
          "fixedPoint": {
            "x": 90,
            "y": 10
          }
        },
        "layout": {
          "left": "50%",
          "top": "70%",
          "height": "10%",
          "isSquare": true,
          "anchor": "center"
        },
        "baseType": "button",
        "cssClasses": "round-button"
      }
    }
  ]
}
