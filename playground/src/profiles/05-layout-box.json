{
  "meta": {
    "name": "05-layout-box: Responsive Scaling",
    "version": "1.0",
    "author": "Omnipad",
    "description": "A practical look at how the LayoutBox maps configuration to CSS positioning. See how various units like px, %, and vh/vw are used to define component constraints, ensuring predictable layouts across different screen scales without complex logic."
  },
  "items": [
    {
      "id": "$left-pad",
      "type": "root-layer",
      "config": {
        "layout": {
          "left": 0,
          "top": 0,
          "width": "100%",
          "height": "100%"
        },
        "baseType": "root-layer"
      }
    },
    {
      "id": "$right-pad",
      "type": "root-layer",
      "config": {
        "layout": {
          "left": 0,
          "top": 0,
          "width": "100%",
          "height": "100%"
        },
        "baseType": "root-layer"
      }
    },
    {
      "id": "node_1",
      "type": "trackpad",
      "parentId": "$left-pad",
      "config": {
        "label": "TRACKPAD",
        "targetStageId": "$ruffle-player",
        "mapping": {
          "type": "mouse"
        },
        "layout": {
          "left": "50%",
          "top": "30%",
          "height": "20vh",
          "width": "20vw",
          "anchor": "center"
        },
        "sensitivity": 0.3,
        "baseType": "trackpad"
      }
    },
    {
      "id": "node_2",
      "type": "d-pad",
      "parentId": "$left-pad",
      "config": {
        "threshold": 0.3,
        "mapping": {
          "up": {
            "code": "ArrowUp"
          },
          "down": {
            "code": "ArrowDown"
          },
          "left": {
            "code": "ArrowLeft"
          },
          "right": {
            "code": "ArrowRight"
          }
        },
        "targetStageId": "$ruffle-player",
        "layout": {
          "left": "50%",
          "top": "70%",
          "height": "10rem",
          "isSquare": true,
          "anchor": "center"
        },
        "baseType": "d-pad"
      }
    },
    {
      "id": "node_3",
      "type": "button",
      "parentId": "$right-pad",
      "config": {
        "label": "CLICK",
        "targetStageId": "$ruffle-player",
        "mapping": {
          "type": "mouse"
        },
        "layout": {
          "left": "200px",
          "top": "150px",
          "height": "100px",
          "width": "100px",
          "anchor": "center"
        },
        "baseType": "button"
      }
    },
    {
      "id": "node_4",
      "type": "joystick",
      "parentId": "$right-pad",
      "config": {
        "label": "R",
        "threshold": 0.1,
        "cursorMode": true,
        "cursorSensitivity": 1.2,
        "targetStageId": "$ruffle-player",
        "mapping": {
          "left": {
            "code": "ArrowLeft"
          },
          "right": {
            "code": "ArrowRight"
          },
          "down": {
            "code": "ArrowDown"
          },
          "stick": {
            "type": "mouse"
          }
        },
        "layout": {
          "left": "50%",
          "top": "70%",
          "width": "25%",
          "height": "20%",
          "anchor": "center"
        },
        "baseType": "joystick"
      }
    }
  ]
}
