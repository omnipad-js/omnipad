{
  "meta": {
    "name": "09-full-gamepad-layout: Physical Hardware Mapping",
    "version": "1.0",
    "author": "OmniPad",
    "description": "A complete 1:1 demonstration of the Gamepad API integration. This profile maps every standard controller button and axis to a corresponding virtual widget, creating a perfect bridge between physical console hardware and web-based game engines."
  },
  "items": [
    {
      "id": "$left-pad",
      "type": "root-layer",
      "config": {
        "layout": {
          "left": 0,
          "top": 0,
          "width": "100%",
          "height": "100%"
        },
        "baseType": "root-layer"
      }
    },
    {
      "id": "node_1",
      "type": "d-pad",
      "parentId": "$left-pad",
      "config": {
        "showStick": false,
        "threshold": 0.3,
        "mapping": {
          "up": {
            "code": "ArrowUp"
          },
          "down": {
            "code": "ArrowDown"
          },
          "left": {
            "code": "ArrowLeft"
          },
          "right": {
            "code": "ArrowRight"
          }
        },
        "targetStageId": "$ruffle-player",
        "layout": {
          "left": "60%",
          "top": "70%",
          "height": "25%",
          "isSquare": true,
          "anchor": "center"
        },
        "baseType": "d-pad"
      }
    },
