{
  "meta": {
    "name": "02-trackpad: Relative Cursor Control",
    "version": "1.0",
    "author": "Omnipad",
    "description": "Learn how to implement fluid cursor movement using the Trackpad component. This setup combines a mouse button with a touch-sensitive trackpad, showcasing relative displacement logic and gesture-based *Double-tap & Hold* for dragging actions."
  },
  "items": [
    {
      "id": "$left-pad",
      "type": "root-layer",
      "config": {
        "layout": {
          "left": 0,
          "top": 0,
          "width": "100%",
          "height": "100%"
        },
        "baseType": "root-layer"
      }
    },
    {
      "id": "$right-pad",
      "type": "root-layer",
      "config": {
        "layout": {
          "left": 0,
          "top": 0,
          "width": "100%",
          "height": "100%"
        },
        "baseType": "root-layer"
      }
    },
    {
      "id": "node_1",
      "type": "button",
      "parentId": "$left-pad",
      "config": {
        "label": "CLICK",
        "targetStageId": "$ruffle-player",
        "mapping": {
          "type": "mouse"
        },
        "layout": {
          "left": "50%",
          "top": "70%",
          "height": 80,
          "width": "80px",
          "anchor": "center"
        },
        "baseType": "button"
      }
    },
    {
      "id": "node_2",
      "type": "trackpad",
      "parentId": "$right-pad",
      "config": {
        "label": "TRACKPAD",
        "targetStageId": "$ruffle-player",
        "mapping": {
          "type": "mouse"
        },
        "layout": {
          "left": "50%",
          "top": "70%",
          "height": "20%",
          "isSquare": true,
          "anchor": "center"
        },
        "sensitivity": 0.3,
        "baseType": "trackpad"
      }
    }
  ]
}
