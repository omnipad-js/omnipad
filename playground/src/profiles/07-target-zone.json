{
  "meta": {
    "name": "07-target-zone: Visual Feedback Customization",
    "version": "1.0",
    "author": "OmniPad",
    "description": "Specific demonstration of the TargetZone properties. Learn how to toggle the virtual cursor via cursorEnabled and control its visibility duration with cursorAutoDelay, all while ensuring the browser focus correctly follows the simulated input."
  },
  "items": [
    {
      "id": "$left-pad",
      "type": "root-layer",
      "config": {
        "layout": {
          "left": 0,
          "top": 0,
          "width": "100%",
          "height": "100%"
        },
        "baseType": "root-layer"
      }
    },
    {
      "id": "$right-pad",
      "type": "root-layer",
      "config": {
        "layout": {
          "left": 0,
          "top": 0,
          "width": "100%",
          "height": "100%"
        },
        "baseType": "root-layer"
      }
    },
    {
      "id": "$ruffle-player",
      "type": "target-zone",
      "config": {
        "cursorAutoDelay": 0,
        "cursorEnabled": true,
        "baseType": "target-zone",
        "layout": {}
      }
    },
    {
      "id": "node_1",
      "type": "trackpad",
      "parentId": "$left-pad",
      "config": {
        "label": "TRACKPAD",
        "targetStageId": "$ruffle-player",
        "mapping": {
          "type": "mouse"
        },
        "layout": {
          "left": "50%",
          "top": "50%",
          "height": "30%",
          "isSquare": true,
          "anchor": "center"
        },
        "sensitivity": 2,
        "baseType": "trackpad"
      }
    }
  ]
}
