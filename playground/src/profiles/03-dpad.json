{
  "meta": {
    "name": "03-dpad: Directional Digital Input",
    "version": "1.0",
    "author": "OmniPad",
    "description": "Compare the visual and functional variations of the classic D-pad. One side features a minimalist interface with a hidden stick handle, while the other provides explicit visual feedback using an active floating handle to guide the user's input."
  },
  "items": [
    {
      "id": "$left-pad",
      "type": "root-layer",
      "config": {
        "layout": {
          "left": 0,
          "top": 0,
          "width": "100%",
          "height": "100%"
        },
        "baseType": "root-layer"
      }
    },
    {
      "id": "$right-pad",
      "type": "root-layer",
      "config": {
        "layout": {
          "left": 0,
          "top": 0,
          "width": "100%",
          "height": "100%"
        },
        "baseType": "root-layer"
      }
    },
    {
      "id": "node_1",
      "type": "d-pad",
      "parentId": "$left-pad",
      "config": {
        "threshold": 0.3,
        "mapping": {
          "up": {
            "code": "ArrowUp"
          },
          "down": {
            "code": "ArrowDown"
          },
          "left": {
            "code": "ArrowLeft"
          },
          "right": {
            "code": "ArrowRight"
          }
        },
        "targetStageId": "$ruffle-player",
        "layout": {
          "left": "50%",
          "top": "70%",
          "width": "150px",
          "height": "150px",
          "anchor": "center"
        },
        "baseType": "d-pad"
      }
    },
    {
      "id": "node_2",
      "type": "d-pad",
      "parentId": "$right-pad",
      "config": {
        "showStick": true,
        "threshold": 0.5,
        "mapping": {
          "up": {
            "code": "ArrowUp"
          },
          "down": {
            "code": "ArrowDown"
          }
        },
        "targetStageId": "$ruffle-player",
        "layout": {
          "left": "50%",
          "top": "70%",
          "width": "150px",
          "height": "150px",
          "anchor": "center"
        },
        "baseType": "d-pad"
      }
    }
  ]
}
